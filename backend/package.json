{
  "name": "admitguard-backend",
  "version": "1.0.0",
  "description": "AdmitGuard — ALOO University Admission Compliance Backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:init": "psql $DATABASE_URL -f src/db/schema.sql",
    "migrate:up": "dotenv -e .env -- node-pg-migrate up   --migrations-dir migrations --database-url-var DATABASE_URL",
    "migrate:down": "dotenv -e .env -- node-pg-migrate down --migrations-dir migrations --database-url-var DATABASE_URL",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "node-pg-migrate": "^8.0.4",
    "pino-pretty": "^11.2.1"
  }
}
