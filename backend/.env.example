# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/admitguard

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=8h

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Google Sheets export (optional — required only for the /api/export/google-sheets route)
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/absolute/path/to/service-account.json
# GOOGLE_SHEET_ID=your_google_sheet_id_here
